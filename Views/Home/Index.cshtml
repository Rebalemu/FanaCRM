@{
    ViewData["Title"] = "Home";
}

<section class="hero-section d-flex align-items-center">
    <div class="container">
        <div class="row align-items-center">
            
            <!-- Left Content -->
            <div class="col-md-6">
                <h1 class="display-4 fw-bold">
                    Manage Your Customers Smarter
                </h1>
                <p class="lead text-muted mt-3">
                    A powerful CRM system to track leads, manage relationships,
                    and grow your business efficiently.
                </p>

                <div class="mt-4">
                    <a href="/Account/Register" class="btn btn-primary btn-lg me-3">
                        Get Started
                    </a>
                    <a href="/Home/About" class="btn btn-outline-secondary btn-lg">
                        Learn More
                    </a>
                </div>

                <div class="mt-4 text-muted small">
                    ✔ Lead Tracking &nbsp;&nbsp;
                    ✔ Sales Pipeline &nbsp;&nbsp;
                    ✔ Analytics Dashboard
                </div>
            </div>

            <!-- Right Image -->
            <div class="col-md-6 text-center">
                <img src="~/images/crm-dashboard.jpg" alt="CRM Dashboard" class="img-fluid hero-image" />
            </div>
        </div>
    </div>
</section>
@* features section *@
<section class="py-5">
    <div class="container text-center">
        <h2 class="fw-bold text-primary mb-3">Features built for growth</h2>
        <p class="text-muted mb-5">Simple tools that help you manage customers and close more deals.</p>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="p-4 border rounded h-100">
                    <h5 class="fw-bold">Customer Management</h5>
                    <p class="text-muted mb-0">Keep all your contacts organized and accessible in one place.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 border rounded h-100">
                    <h5 class="fw-bold">Sales Pipeline</h5>
                    <p class="text-muted mb-0">Track deals visually and move leads through your pipeline.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 border rounded h-100">
                    <h5 class="fw-bold">Analytics & Reports</h5>
                    <p class="text-muted mb-0">Make smarter decisions with real-time performance insights.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 border rounded h-100">
                    <h5 class="fw-bold">Automation</h5>
                    <p class="text-muted mb-0">Automate repetitive tasks and save valuable time.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 border rounded h-100">
                    <h5 class="fw-bold">Integrations</h5>
                    <p class="text-muted mb-0">Connect with email, tools, and third-party services easily.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 border rounded h-100">
                    <h5 class="fw-bold">Secure Cloud</h5>
                    <p class="text-muted mb-0">Your data is safe, encrypted, and available anytime.</p>
                </div>
            </div>

        </div>
    </div>
</section>

@* Pricing Section *@
<section class="py-5 bg-light">
    <div class="container text-center">
        <h2 class="fw-bold text-primary mb-3">Simple, transparent pricing</h2>
        <p class="text-muted mb-5">No hidden fees. Upgrade as your business grows.</p>

        <div class="row g-4 justify-content-center">

            <!-- Basic -->
            <div class="col-md-4">
                <div class="p-4 border rounded h-100 bg-white">
                    <h6 class="text-uppercase text-muted">Basic</h6>
                    <h2 class="fw-bold my-3">$9</h2>
                    <p class="text-muted">per month</p>

                    <ul class="list-unstyled mb-4 text-muted">
                        <li>✔ 1 User</li>
                        <li>✔ Contact Management</li>
                        <li>✔ Basic Reports</li>
                        <li class="text-muted">✖ Automation</li>
                    </ul>

                    <a href="/Account/Register" class="btn btn-outline-primary w-100">
                        Get Started
                    </a>
                </div>
            </div>

            <!-- Pro (highlighted) -->
            <div class="col-md-4">
                <div class="p-4 border border-primary rounded h-100 bg-white">
                    <span class="badge bg-primary mb-2">Most Popular</span>
                    <h6 class="text-uppercase text-muted">Pro</h6>
                    <h2 class="fw-bold my-3 text-primary">$29</h2>
                    <p class="text-muted">per month</p>

                    <ul class="list-unstyled mb-4 text-muted">
                        <li>✔ Up to 5 Users</li>
                        <li>✔ Advanced Reports</li>
                        <li>✔ Automation</li>
                        <li>✔ Email Integration</li>
                    </ul>

                    <a href="/Account/Register" class="btn btn-primary w-100">
                        Start Free Trial
                    </a>
                </div>
            </div>

            <!-- Enterprise -->
            <div class="col-md-4">
                <div class="p-4 border rounded h-100 bg-white">
                    <h6 class="text-uppercase text-muted">Enterprise</h6>
                    <h2 class="fw-bold my-3">$79</h2>
                    <p class="text-muted">per month</p>

                    <ul class="list-unstyled mb-4 text-muted">
                        <li>✔ Unlimited Users</li>
                        <li>✔ Full Analytics</li>
                        <li>✔ API Access</li>
                        <li>✔ Priority Support</li>
                    </ul>

                    <a  asp-controller="Home" asp-action="Contact" class="btn btn-outline-secondary w-100">
                        Contact Sales
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>