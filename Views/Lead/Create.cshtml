@model LeadCreateVM

@{
    ViewData["Title"] = "Create Lead";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4>Create New Lead</h4>
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control" autofocus />
                        <span asp-validation-for="FullName" class="invalid-feedback"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Company" class="form-label"></label>
                        <input asp-for="Company"
                               class="form-control @(ViewData.ModelState["Company"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="Company name" />
                        <span asp-validation-for="Company" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email"
                               class="form-control @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="Email address" />
                        <span asp-validation-for="Email" class="invalid-feedback"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone"
                               class="form-control @(ViewData.ModelState["Phone"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="Phone number" />
                        <span asp-validation-for="Phone" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="SourceId" class="form-label"></label>
                        <select asp-for="SourceId"
                                class="form-select @(ViewData.ModelState["SourceId"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                asp-items="Model.Sources ?? new List<SelectListItem>()">
                            <option value="">-- Select Source --</option>
                        </select>
                        <span asp-validation-for="SourceId" class="invalid-feedback"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="StatusId" class="form-label"></label>
                        <select asp-for="StatusId"
                                class="form-select @(ViewData.ModelState["StatusId"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                asp-items="Model.Statuses ?? new List<SelectListItem>()">
                            <option value="">-- Select Status --</option>
                        </select>
                        <span asp-validation-for="StatusId" class="invalid-feedback"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="AssignedTo" class="form-label"></label>
                        <select asp-for="AssignedTo"
                                class="form-select @(ViewData.ModelState["AssignedTo"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                asp-items="Model.Users ?? new List<SelectListItem>()">
                            <option value="">-- Unassigned --</option>
                        </select>
                        <span asp-validation-for="AssignedTo" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="mt-3 d-flex justify-content-between">
                    <a asp-controller="Lead" asp-action="Index" class="btn btn-secondary">Back</a>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle"></i> Create Lead
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}