@using FanaCRM.ViewModels
@model List<LeadIndexVM>

@{
    ViewData["Title"] = "Leads";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Leads Management</h3>
        <a asp-action="Create" class="btn btn-primary">+ New Lead</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form method="get" class="row mb-3">
                <div class="col-md-4">
                    <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control"
                           placeholder="Search by name..." />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-primary">Search</button>
                </div>
            </form>
            <table class="table table-hover table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Company</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Source</th>
                        <th>Status</th>
                        <th>Assigned To</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.FullName</td>
                                <td>@item.Company</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Email))
                                    {
                                        <a href="mailto:@item.Email">@item.Email</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td>@item.Phone</td>
                                <td>@item.Source </td>
                                <td>
                                    @{
                                        var statusClass = item.Status switch
                                        {
                                            "New" => "bg-primary",
                                            "Contacted" => "bg-warning",
                                            "Qualified" => "bg-success",
                                            "Lost" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @statusClass">@item.Status</span>
                                </td>
                                <td>
                                    @(string.IsNullOrEmpty(item.AssignedTo) ? "Unassigned" : item.AssignedTo)
                                </td>
                                <td>@item.CreatedDate.ToString("yyyy-MM-dd")</td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning mx-1">
                                            <i class="bi bi-pencil-square"></i> Edit
                                        </a>
                                        <button type="button" class="btn btn-sm btn-danger mx-1" data-bs-toggle="modal"
                                                data-bs-target="#deleteModal" data-id="@item.Id">
                                            <i class="bi bi-trash-fill"></i> Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted">
                                No leads found. Try adjusting your search.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>



@await Html.PartialAsync("_DeleteModal")